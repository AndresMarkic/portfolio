# Copiá este archivo como .env.local y completá los valores.

# Secreto para firmar la sesión. Generá uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="cambiar-por-uno-random-de-32-bytes"

# URL del sitio (en prod: tu dominio real, p. ej. https://tu-dominio.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Email para entrar al panel /admin
ADMIN_EMAIL="admin@portfolio.com"

# Contraseña hasheada con bcrypt. Generala con:
#   npm run set-password "TuClaveSegura"
# y pegá acá el hash (escapando los $ como \$).
ADMIN_PASSWORD_HASH="\$2b\$10\$reemplazar-por-tu-hash-bcrypt"

# Alternativa rápida (menos segura): contraseña en texto plano.
# Si definís ADMIN_PASSWORD_HASH, este valor se ignora.
# ADMIN_PASSWORD="tu-clave"
